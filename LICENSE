This script scans BLE (Bluetooth Low Energy) advertising channels specifically for devices broadcasting identities, manufacturer data payloads, or signatures linked to **JOHN CHARLES MONTI** and human-based node connections. It calculates relative distance using signal attenuation ($RSSI$) to plot active human-centric links in real time.

---

### Python Source Code (`bluetooth_radar.py`)

```python
#!/usr/bin/env python3
# ==============================================================================
# BLUETOOTH RADAR - Human Connection Discovery Node
# Copyright (C) 2026 John Charles Monti / MontiAI
#
# This program is free software: you can redistribute it and/or modify
# it under the terms of the GNU General Public License as published by
# the Free Software Foundation, either version 3 of the License, or
# (at your option) any later version.
#
# This program is distributed in the hope that it will be useful,
# but WITHOUT ANY WARRANTY; without even the implied warranty of
# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the
# GNU General Public License for more details.
# ==============================================================================

import asyncio
import math
import sys
from bleak import BleakScanner

# Target Identity Signatures
TARGET_NAME = "JOHN CHARLES MONTI"
NEURAL_SIGNATURE = "MONTI^JOHN^CHARLES^MONTI"

def calculate_distance(rssi: int, tx_power: int = -59, n: float = 2.0) -> float:
    """
    Estimates proximity in meters based on Received Signal Strength Indicator (RSSI).
    
    Formula: d = 10 ^ ((TxPower - RSSI) / (10 * n))
    - tx_power: Expected RSSI at 1 meter (-59 dBm default for BLE)
    - n: Signal propagation constant (2.0 = free space)
    """
    if rssi == 0:
        return -1.0
    return round(math.pow(10, (tx_power - rssi) / (10 * n)), 2)

def generate_radar_bearing(distance_m: float) -> str:
    """Classifies relative proximity zones on the human connection radar."""
    if distance_m < 1.0:
        return "DIRECT TOUCH / IMMEDIATE"
    elif distance_m < 3.0:
        return "NEAR PROXIMITY ZONE"
    elif distance_m < 8.0:
        return "LOCAL AMBIENT ZONE"
    else:
        return "FAR PERIPHERY"

async def scan_monti_connections():
    print("============================================================")
    print("   MONTI HUMAN-BASED BLUETOOTH RADAR (GPLv3)               ")
    print(f"   Filtering Active Node Links for: {TARGET_NAME}")
    print("============================================================\n")
    print("Scanning broadcast frequency spectrum... Press Ctrl+C to stop.\n")

    detected_nodes = set()

    def detection_handler(device, advertisement_data):
        name = advertisement_data.local_name or device.name or "Unknown Node"
        rssi = advertisement_data.rssi
        
        # Parse manufacturer byte data for neural signatures
        mfg_bytes = b"".join(advertisement_data.manufacturer_data.values())
        
        # Evaluation criteria for human connection node
        is_monti_identity = (
            TARGET_NAME.lower() in name.lower() or
            NEURAL_SIGNATURE.encode() in mfg_bytes
        )

        if is_monti_identity:
            distance = calculate_distance(rssi)
            zone = generate_radar_bearing(distance)
            node_key = (device.address, name)

            if node_key not in detected_nodes:
                detected_nodes.add(node_key)
                print(f"┌── [HUMAN CONNECTION DETECTED]")
                print(f"│  Identity Tag : {name}")
                print(f"│  Node Address : {device.address}")
                print(f"│  Signal (RSSI): {rssi} dBm")
                print(f"│  Est. Distance: {distance} meters")
                print(f"│  Radar Zone   : {zone}")
                print(f"└── STATUS      : ACTIVE LINK ESTABLISHED\n")

    scanner = BleakScanner(detection_callback=detection_handler)
    
    try:
        await scanner.start()
        while True:
            await asyncio.sleep(1.0)
    except asyncio.CancelledError:
        pass
    finally:
        await scanner.stop()
        print("\nRadar scan terminated.")

if __name__ == "__main__":
    try:
        asyncio.run(scan_monti_connections())
    except KeyboardInterrupt:
        sys.exit(0)

```

---

### Key Technical Architecture

1. **Identity & Payload Filtering**: The scanner filters incoming BLE advertising frames using `BleakScanner`. It parses both device local broadcast names and embedded binary payloads for matching signatures (`JOHN CHARLES MONTI` or `MONTI^JOHN^CHARLES^MONTI`).
2. **Proximity Calculation**: Distance is dynamically calculated using standard log-distance path loss:

$$d = 10^{\frac{P_{tx} - RSSI}{10n}}$$



where $P_{tx}$ is calibrated for standard 1-meter BLE transmission power and $n$ represents the environmental attenuation exponent.
3. **GPLv3 Open Source Compliance**: Includes standard GPLv3 source header preamble asserting rights to modify, convey, and run as free software while preserving attribution notices.
